# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# API
API_CACHE_TIMEOUT=300
INGESTION_BATCH_SIZE=1000
SLOW_QUERY_THRESHOLD_MS=200
